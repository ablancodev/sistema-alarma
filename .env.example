# IMPORTANTE: los comentarios deben ir en su PROPIA línea (no "VAR=valor # ...").
# Docker Compose NO quita los comentarios en línea: se los traga como parte del valor.

# ─── Red local (lo rellena ./generate-cert.sh) ───
LAN_HOST=localhost
LAN_IP=127.0.0.1

# ─── Captura ───
# cada cuántos segundos saca foto el móvil
CAPTURE_INTERVAL_SECONDS=3
# 0..1, calidad de la foto que envía el móvil
JPEG_QUALITY=0.6

# ─── Detección de movimiento ───
# sensibilidad por píxel (0-255, menor = más sensible)
MOTION_THRESHOLD=25
# fracción de píxeles que deben cambiar para contar como movimiento (0.02 = 2%)
MOTION_MIN_RATIO=0.02

# ─── IA (versión 2.0) ───
# false = v1.0 (sin IA) | true = v2.0 (con IA)
AI_ENABLED=false
# la IA solo se llama si el cambio supera este umbral (0.05 = 5%)
AI_MIN_RATIO=0.05
# longitud máx. de la descripción (menos tokens = algo más rápido)
AI_MAX_TOKENS=40
# se reduce la imagen antes de enviarla al modelo
AI_IMAGE_MAX_PX=512
# mantener el modelo en memoria entre llamadas
AI_KEEP_ALIVE=10m
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=moondream
# moondream es un modelo pequeño de subtítulos: usa un prompt SIMPLE en inglés.
# Prompts largos o con varias instrucciones hacen que devuelva vacío.
AI_PROMPT=Describe this image.
# Vacío = alerta siempre. Si pones keywords (coma-separado), solo alerta cuando
# la descripción de la IA las contiene. Ej: person,man,woman,dog,cat,car
ALERT_KEYWORDS=

# ─── Notificaciones ───
# canales: telegram, email o "telegram,email"
NOTIFY_CHANNELS=telegram

# ─── Telegram (recomendado: instantáneo y simple) ───
# 1) En Telegram habla con @BotFather -> /newbot -> te da el TOKEN.
# 2) Escribe a tu bot un "hola" y saca tu chat id con @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# mínimo entre alertas base (movimiento)
NOTIFY_COOLDOWN_SECONDS=120
# mínimo entre mensajes de interpretación IA (cooldown independiente)
AI_NOTIFY_COOLDOWN_SECONDS=120

# ─── Email (opcional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=app_password_de_16_letras
EMAIL_FROM=tucorreo@gmail.com
EMAIL_TO=destino@ejemplo.com

# ─── Almacenamiento ───
DATA_DIR=/data
# imágenes más antiguas se borran (0 = nunca)
RETENTION_DAYS=7
